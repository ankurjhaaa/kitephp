{
    "name": "echovel/kitephp",
    "version": "0.0.3",
    "type": "project",
    "description": "The Full Stack PHP Micro-Framework with a built-in SPA Reactive Engine.",
    "keywords": ["framework", "php", "spa", "micro-framework", "reactive"],
    "license": "MIT",
    "authors": [
        {
            "name": "Ankur Jha",
            "email": "ankur@echovel.com"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../framework"
        }
    ],
    "require": {
        "php": "^8.0",
        "echovel/framework": "^0.0.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Controller\\": "app/controller/",
            "App\\Middleware\\": "app/middleware/",
            "App\\Service\\": "app/service/",
            "Database\\": "database/"
        },
        "files": [
            "helper/functions.php"
        ]
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
